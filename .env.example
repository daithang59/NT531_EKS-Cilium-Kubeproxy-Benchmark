# ==============================================================================
# .env — Benchmark environment variables
# ==============================================================================
# Sao chép template và điền giá trị thực:
#   cp .env.example .env
#
# Load trước khi chạy benchmark:
#   set -a && source .env && set +a
#
# ==============================================================================

# ----- Mode (A = kube-proxy, B = eBPF KPR) -----
MODE=A

# ----- Load level (L1 = light, L2 = medium, L3 = high) -----
# Giá trị QPS/CONNS sẽ được calibration override trong common.sh
LOAD=L1

# ----- Benchmark repeats per combination -----
REPEAT=3

# ----- Timing (seconds) -----
WARMUP_SEC=30
DURATION_SEC=180
REST_BETWEEN_RUNS=60
